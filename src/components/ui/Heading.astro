---
export interface Props {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl' | '6xl';
  weight?: 'normal' | 'medium' | 'semibold' | 'bold' | 'extrabold';
  color?: 'primary' | 'secondary' | 'accent' | 'dark' | 'light' | 'white' | 'on-dark' | 'on-primary' | 'on-secondary' | 'on-accent' | 'inherit';
  class?: string;
}

const { 
  level = 2, 
  size = 'lg', 
  weight = 'bold', 
  color = 'dark',
  class: className = '',
  ...props 
} = Astro.props;

const sizeClasses = {
  sm: 'text-base sm:text-lg',
  md: 'text-lg sm:text-xl',
  lg: 'text-xl sm:text-2xl',
  xl: 'text-2xl sm:text-3xl',
  '2xl': 'text-3xl sm:text-4xl',
  '3xl': 'text-4xl sm:text-5xl',
  '4xl': 'text-5xl sm:text-6xl',
  '5xl': 'text-5xl sm:text-6xl md:text-7xl',
  '6xl': 'text-6xl sm:text-7xl md:text-8xl'
};

const weightClasses = {
  normal: 'font-normal',
  medium: 'font-medium',
  semibold: 'font-semibold', 
  bold: 'font-bold',
  extrabold: 'font-extrabold'
};

const colorClasses = {
  primary: 'text-primary',
  secondary: 'text-secondary',
  accent: 'text-accent',
  dark: 'text-text-main',
  light: 'text-text-on-dark',
  white: 'text-white',
  'on-dark': 'text-on-dark',
  'on-primary': 'text-on-primary',
  'on-secondary': 'text-on-secondary',
  'on-accent': 'text-on-accent',
  inherit: ''
};

const baseClasses = `${sizeClasses[size]} ${weightClasses[weight]} ${colorClasses[color]} ${className}`;
---

{level === 1 && <h1 class={baseClasses} {...props}><slot /></h1>}
{level === 2 && <h2 class={baseClasses} {...props}><slot /></h2>}
{level === 3 && <h3 class={baseClasses} {...props}><slot /></h3>}
{level === 4 && <h4 class={baseClasses} {...props}><slot /></h4>}
{level === 5 && <h5 class={baseClasses} {...props}><slot /></h5>}
{level === 6 && <h6 class={baseClasses} {...props}><slot /></h6>}

