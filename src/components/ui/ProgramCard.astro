---
import BrutalCard from './BrutalCard.astro';
import Heading from './Heading.astro';
import Text from './Text.astro';

interface Props {
  icon?: string;
  title: string;
  description: string;
  schedule?: string;
  level?: string;
  participants?: string;
  variant?: 'primary' | 'secondary' | 'accent' | 'surface' | 'dark' | 'white';
  rotation?: 'left' | 'right' | 'none';
  className?: string;
}

const { 
  icon = "🔬", 
  title, 
  description,
  schedule,
  level,
  participants,
  variant = "primary", 
  rotation = "left",
  className = ""
} = Astro.props;

const textColor = variant === 'primary' ? 'on-primary' : 
                  variant === 'secondary' ? 'on-secondary' : 
                  variant === 'accent' ? 'on-accent' : 
                  variant === 'surface' || variant === 'white' ? 'main' : 'on-dark';
---

<BrutalCard variant={variant} rotation={rotation} class={`p-6 ${className}`}>
  <div class="text-4xl mb-4">{icon}</div>
  <Heading level={3} size="lg" color={textColor} class="uppercase mb-3">{title}</Heading>
  <Text color={textColor} class="font-semibold mb-4">{description}</Text>
  
  {(schedule || level || participants) && (
    <div class="border-t-2 border-border-main pt-3 mt-3 space-y-2">
      {schedule && (
        <Text color={textColor} size="sm" class="font-bold">
          📅 {schedule}
        </Text>
      )}
      {level && (
        <Text color={textColor} size="sm" class="font-bold">
          📊 Level: {level}
        </Text>
      )}
      {participants && (
        <Text color={textColor} size="sm" class="font-bold">
          👥 {participants}
        </Text>
      )}
    </div>
  )}
</BrutalCard>
