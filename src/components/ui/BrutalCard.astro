---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'surface' | 'dark' | 'white' | 'custom';
  size?: 'sm' | 'md' | 'lg';
  rotation?: 'left' | 'right' | 'none';
  urgent?: boolean;
  className?: string;
}

const { 
  variant = 'primary',
  size = 'md', 
  rotation = 'none',
  urgent = false,
  className = ""
} = Astro.props;

const variantClasses = {
  primary: 'bg-primary text-text-on-primary',
  secondary: 'bg-secondary text-text-on-secondary', 
  accent: 'bg-accent text-text-on-accent',
  surface: 'bg-surface text-text-main',
  dark: 'bg-text-main text-on-dark',
  white: 'bg-white text-text-main',
  glass: 'glass text-text-main',
  custom: ''
};

const sizeClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const rotationClasses = {
  left: 'transform -rotate-1 hover:rotate-0',
  right: 'transform rotate-1 hover:rotate-0', 
  none: ''
};

const cardClasses = `${variantClasses[variant]} ${sizeClasses[size]} ${rotationClasses[rotation]} border-4 border-border-main shadow-brutal-sm transition-transform hover:scale-105 relative ${className}`;
---

<div class={cardClasses}>
  {urgent && (
    <div class="absolute -top-3 -right-3 bg-red-700 border-2 border-border-main px-2 py-1 transform rotate-12">
      <span class="text-xs font-black text-white">URGENT!</span>
    </div>
  )}
  
  <slot />
</div>
