---
export interface Props {
  size?: 'sm' | 'md' | 'lg';
  color?: 'primary' | 'secondary' | 'accent' | 'muted' | 'main' | 'on-dark' | 'on-primary' | 'on-secondary' | 'on-accent' | 'white' | 'inherit';
  leading?: 'tight' | 'normal' | 'relaxed';
  class?: string;
}

const { 
  size = 'md', 
  color = 'primary', 
  leading = 'normal',
  class: className = '',
  ...props 
} = Astro.props;

const sizeClasses = {
  sm: 'text-xs sm:text-sm',
  md: 'text-sm sm:text-base',
  lg: 'text-base sm:text-lg'
};

const colorClasses = {
  primary: 'text-primary',
  secondary: 'text-secondary',
  accent: 'text-accent',
  muted: 'text-muted',
  main: 'text-main',
  'on-dark': 'text-on-dark',
  'on-primary': 'text-on-primary',
  'on-secondary': 'text-on-secondary',
  'on-accent': 'text-on-accent',
  white: 'text-white',
  inherit: ''
};

const leadingClasses = {
  tight: 'leading-tight',
  normal: 'leading-normal',
  relaxed: 'leading-relaxed'
};

const baseClasses = `${sizeClasses[size]} ${colorClasses[color]} ${leadingClasses[leading]} ${className}`;
---

<p class={baseClasses} {...props}>
  <slot />
</p>
