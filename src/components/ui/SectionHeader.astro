---
interface Props {
  title: string;
  subtitle?: string;
  className?: string;
}

const { title, subtitle, className = "" } = Astro.props;
---

<div class={`bg-secondary border-4 border-border-main p-4 transform -rotate-1 inline-block shadow-brutal-sm ${className}`}>
  <h2 class="text-2xl sm:text-3xl font-black uppercase text-on-secondary m-0">{title}</h2>
  {subtitle && <p class="text-on-secondary font-semibold mt-2 mb-0">{subtitle}</p>}
</div>
