---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'surface' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  target?: string;
  rel?: string;
  className?: string;
  type?: 'button' | 'submit' | 'reset';
  id?: string;
  ariaLabel?: string;
}

const { 
  variant = 'primary',
  size = 'md',
  href,
  target,
  rel,
  className = "",
  type = 'button',
  id,
  ariaLabel
} = Astro.props;

const variantClasses = {
  primary: 'btn-primary text-text-on-primary',
  secondary: 'btn-secondary text-text-on-secondary', 
  accent: 'btn-accent text-text-on-accent',
  surface: 'bg-surface text-text-main border-border-main',
  dark: 'bg-text-main text-on-dark border-border-main'
};

const sizeClasses = {
  sm: 'px-3 py-1.5 text-sm min-h-[40px]',
  md: 'px-4 sm:px-6 py-2 sm:py-3 text-sm sm:text-base',
  lg: 'px-5 sm:px-8 py-3 sm:py-4 text-base sm:text-xl'
};

const baseClasses = 'font-black border-2 hover:scale-105 transition-transform inline-block text-center';
const buttonClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

{href ? (
  <a 
    href={href}
    target={target}
    rel={rel}
    class={buttonClasses}
    id={id}
    aria-label={ariaLabel}
  >
    <slot />
  </a>
) : (
  <button 
    type={type}
    class={buttonClasses}
    id={id}
    aria-label={ariaLabel}
  >
    <slot />
  </button>
)}
