---
interface Props {
  title: string;
  icon: string;
  class?: string;
  lazy?: boolean;
  variant?: 'default' | 'gradient';
}
const { title, icon, class: className = "", lazy = false, variant = 'default' } = Astro.props;

const variantStyles = {
  default: 'bg-surface text-text-main',
  gradient: 'bg-gradient-to-r from-primary to-accent text-on-primary'
};

const titleStyles = {
  default: 'text-text-main',
  gradient: 'text-on-primary'
};
---

<div class={`rounded-2xl shadow-sm p-4 pt-0 ${variantStyles[variant]} ${className}`}>
  <h2 class={`font-bold text-lg py-4 mb-0 flex items-center gap-2 ${titleStyles[variant]}`}>
    <span class="text-xl">{icon}</span> {title}
  </h2>
  <div class={lazy ? "lazy-content" : ""}>
    <slot />
  </div>
</div>

<style>
  .lazy-content {
    min-height: 100px;
    content-visibility: auto;
    contain-intrinsic-size: 0 100px;
  }
</style>
