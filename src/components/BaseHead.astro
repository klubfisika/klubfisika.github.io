---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	article?: boolean;
	publishDate?: Date;
	modifiedDate?: Date;
	author?: string;
	tags?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { 
	title, 
	description, 
	image = '/kf13-logo.png',
	article = false,
	publishDate,
	modifiedDate,
	author = 'KF13 - Klub Fisika Indonesia',
	tags = []
} = Astro.props;

const fullTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="language" content="Indonesian" />
<meta name="geo.region" content="ID" />
<meta name="geo.placename" content="Indonesia" />

<!-- Theme Script (Anti-flicker) - Must be before any content -->
<script>
  // Prevent theme flicker by setting theme immediately
  (function() {
    try {
      const theme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      
      if (theme === 'dark' || (!theme && prefersDark)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    } catch (e) {
      // Fallback for environments without localStorage
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark');
      }
    }
  })();
</script>

<!-- Font Preconnect & Preload (Performance Optimization) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&display=swap"
  rel="stylesheet"
/>

<!-- favicon -->
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="theme-color" content="#1e40af" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#3b82f6" media="(prefers-color-scheme: dark)" />
<meta name="msapplication-TileColor" content="#1e40af" />

<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="keywords" content="klub fisika indonesia, komunitas fisika, belajar fisika, eksperimen fisika, KF13, komunitas sains indonesia, fisika pelajar, pembelajaran fisika, tutorial fisika, teori fisika, mekanika, termodinamika, optik, listrik, magnet, fisika modern, fisika kuantum" />
<meta name="author" content={author} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta name="revisit-after" content="7 days" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.site)} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="KF13 - Klub Fisika Indonesia" />
<meta property="og:locale" content="id_ID" />
<meta property="og:locale:alternate" content="en_US" />

{article && publishDate && (
	<>
		<meta property="article:published_time" content={publishDate.toISOString()} />
		{modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}
		<meta property="article:author" content={author} />
		{tags.map((tag) => (
			<meta property="article:tag" content={tag} />
		))}
	</>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.site)} />
<meta property="twitter:site" content="@KF13Indonesia" />
<meta property="twitter:creator" content="@KF13Indonesia" />

<!-- Structured Data - Organization -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "KF13 - Klub Fisika Indonesia",
  "alternateName": ["KF13", "Klub Fisika Indonesia"],
  "description": "Komunitas pembelajaran dan eksplorasi fisika untuk generasi muda Indonesia. Menyediakan konten edukasi, eksperimen, dan forum diskusi fisika.",
  "url": "https://klubfisika.github.io",
  "logo": "https://klubfisika.github.io/kf13-logo.png",
  "foundingDate": "2013",
  "email": "info@klubfisika.org",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "info@klubfisika.org",
    "contactType": "customer service",
    "availableLanguage": ["Indonesian", "English"]
  },
  "sameAs": [
    "https://instagram.com/kf13_indonesia",
    "https://twitter.com/KF13Indonesia",
    "https://github.com/klubfisika"
  ]
}
</script>

<!-- Structured Data - WebSite -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "KF13 - Klub Fisika Indonesia",
  "url": "https://klubfisika.github.io",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://klubfisika.github.io/blog?search={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>

{article && publishDate && (
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": title,
		"description": description,
		"image": new URL(image, Astro.site).toString(),
		"author": {
			"@type": "Person",
			"name": author
		},
		"publisher": {
			"@type": "Organization",
			"name": "KF13 - Klub Fisika Indonesia",
			"logo": {
				"@type": "ImageObject",
				"url": "https://klubfisika.github.io/kf13-logo.png"
			}
		},
		"datePublished": publishDate.toISOString(),
		"dateModified": (modifiedDate || publishDate).toISOString(),
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": canonicalURL.toString()
		}
	}
	</script>
)}
